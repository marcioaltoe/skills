---
import data from '../data/skills.json';
import SkillCard from '../components/SkillCard.astro';
import '../styles/global.css';

const { skills, collections, tags, tagsAll, total, repo, generatedAt } = data;

const updated = new Date(generatedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const favicon =
  "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧩</text></svg>";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={favicon} />
    <title>Skills Catalog · {repo}</title>
    <meta
      name="description"
      content={`Browse, search and filter ${total} curated agent skills from ${repo}.`}
    />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <div class="site-header__top">
          <h1>🧩 Skills Catalog</h1>
          <a class="repo-link" href={`https://github.com/${repo}`} target="_blank" rel="noopener noreferrer">
            {repo} ↗
          </a>
        </div>
        <p class="tagline">
          {total} curated agent skills across {collections.length} collections. Search, filter, group,
          and copy the install command for any skill — or a whole collection.
        </p>
      </div>
    </header>

    <section class="controls wrap" aria-label="Filters">
      <div class="search">
        <input
          id="search"
          type="search"
          placeholder="Search skills by name, description, tag, author…  (press /)"
          autocomplete="off"
          aria-label="Search skills"
        />
      </div>

      <div class="filter-row">
        <div class="pills" id="collection-pills" role="group" aria-label="Filter by collection">
          <button class="pill is-active" data-collection="all" type="button">All <span class="pill__n">{total}</span></button>
          {
            collections.map((c) => (
              <button class="pill" data-collection={c.value} type="button">
                {c.label} <span class="pill__n">{c.count}</span>
              </button>
            ))
          }
        </div>

        <div class="selects">
          <label class="select">
            <span>Group</span>
            <select id="group">
              <option value="none">No grouping</option>
              <option value="collection">By collection</option>
              <option value="author">By author</option>
            </select>
          </label>
          <label class="select">
            <span>Sort</span>
            <select id="sort">
              <option value="name-asc">Name (A–Z)</option>
              <option value="name-desc">Name (Z–A)</option>
            </select>
          </label>
        </div>
      </div>

      <div class="tags-filter">
        <div class="tags-filter__head">
          <span class="tags-filter__label">Tags</span>
          <span class="tags-filter__hint">matches all selected</span>
          <label class="toggle">
            <input type="checkbox" id="author-tags-toggle" />
            <span>Include author tags</span>
          </label>
          <button class="tags-clear" id="tags-clear" type="button" hidden>clear tags</button>
        </div>
        <div class="tag-pills" id="tag-pills" data-collapsed="true"></div>
        <button class="tags-toggle" id="tags-toggle" type="button" aria-expanded="false" hidden></button>
      </div>

      <div class="result-bar">
        <p class="result-count" id="result-count" aria-live="polite"></p>
        <div class="collection-install" id="collection-install" hidden>
          <span>Install this collection:</span>
          <code id="collection-install-cmd"></code>
          <button class="btn btn--copy" id="collection-install-btn" type="button">Copy</button>
        </div>
      </div>
    </section>

    <main class="wrap">
      <div id="card-list">
        {skills.map((skill) => <SkillCard skill={skill} />)}
      </div>
      <p class="empty" id="empty" hidden>No skills match your filters.</p>
    </main>

    <footer class="site-footer wrap">
      <span>Generated {updated} · {total} skills</span>
      <a href={`https://github.com/${repo}`} target="_blank" rel="noopener noreferrer">View source on GitHub ↗</a>
    </footer>

    <div class="toast" id="toast" role="status" aria-live="polite" hidden></div>

    <script define:vars={{ repo, TAGS_OUR: tags, TAGS_ALL: tagsAll, FOLD: 28 }}>
      const search = document.getElementById('search');
      const groupSel = document.getElementById('group');
      const sortSel = document.getElementById('sort');
      const collectionPills = Array.from(document.querySelectorAll('#collection-pills .pill'));
      const tagPillsWrap = document.getElementById('tag-pills');
      const tagsClear = document.getElementById('tags-clear');
      const tagsToggle = document.getElementById('tags-toggle');
      const authorTagsToggle = document.getElementById('author-tags-toggle');
      const resultCount = document.getElementById('result-count');
      const empty = document.getElementById('empty');
      const toast = document.getElementById('toast');
      const list = document.getElementById('card-list');
      const collectionInstall = document.getElementById('collection-install');
      const collectionInstallCmd = document.getElementById('collection-install-cmd');
      const collectionInstallBtn = document.getElementById('collection-install-btn');

      const cards = Array.from(list.querySelectorAll('.card'));
      const state = { q: '', collection: 'all', group: 'none', sort: 'name-asc', tags: new Set(), authorTags: false };

      const collInstall = (slug) => `bunx skills add ${repo}/skills/${slug}`;
      const collLabel = (slug) => {
        const card = cards.find((c) => c.dataset.collection === slug);
        return card ? card.dataset.collectionLabel : slug;
      };

      function cardTags(card) {
        const our = card.dataset.tags ? card.dataset.tags.split(',') : [];
        if (!state.authorTags) return our;
        const auth = card.dataset.authorTags ? card.dataset.authorTags.split(',') : [];
        return [...new Set([...our, ...auth])];
      }

      function makeGrid() {
        const grid = document.createElement('div');
        grid.className = 'grid';
        return grid;
      }

      function makeSection(label, count, installCmd) {
        const section = document.createElement('section');
        section.className = 'group';
        const head = document.createElement('div');
        head.className = 'group__head';
        const title = document.createElement('h2');
        title.className = 'group__title';
        title.textContent = label;
        const n = document.createElement('span');
        n.className = 'group__n';
        n.textContent = String(count);
        title.appendChild(n);
        head.appendChild(title);
        if (installCmd) {
          const btn = document.createElement('button');
          btn.className = 'btn btn--copy group__install';
          btn.type = 'button';
          btn.dataset.install = installCmd;
          btn.textContent = 'Copy collection install';
          head.appendChild(btn);
        }
        section.appendChild(head);
        return section;
      }

      function render() {
        const q = state.q.trim().toLowerCase();

        let visible = cards.filter((card) => {
          const matchQ = !q || (card.dataset.search ?? '').includes(q);
          const matchCol = state.collection === 'all' || card.dataset.collection === state.collection;
          const tagsOfCard = cardTags(card);
          const matchTags = state.tags.size === 0 || [...state.tags].every((t) => tagsOfCard.includes(t));
          return matchQ && matchCol && matchTags;
        });

        const dir = state.sort === 'name-desc' ? -1 : 1;
        visible.sort((a, b) => dir * a.dataset.name.localeCompare(b.dataset.name));

        list.replaceChildren();

        if (state.group === 'none') {
          const grid = makeGrid();
          for (const card of visible) grid.appendChild(card);
          list.appendChild(grid);
        } else {
          const byCollection = state.group === 'collection';
          const groups = new Map();
          for (const card of visible) {
            const key = byCollection ? card.dataset.collection : card.dataset.author || '~';
            if (!groups.has(key)) {
              groups.set(key, {
                label: byCollection ? card.dataset.collectionLabel : card.dataset.author || 'Unattributed',
                slug: card.dataset.collection,
                cards: [],
              });
            }
            groups.get(key).cards.push(card);
          }
          const keys = [...groups.keys()].sort((a, b) => groups.get(a).label.localeCompare(groups.get(b).label));
          for (const key of keys) {
            const g = groups.get(key);
            const section = makeSection(g.label, g.cards.length, byCollection ? collInstall(g.slug) : null);
            const grid = makeGrid();
            for (const card of g.cards) grid.appendChild(card);
            section.appendChild(grid);
            list.appendChild(section);
          }
        }

        empty.hidden = visible.length !== 0;
        resultCount.textContent =
          visible.length === cards.length
            ? `Showing all ${visible.length} skills`
            : `Showing ${visible.length} of ${cards.length} skills`;

        if (state.collection !== 'all') {
          collectionInstall.hidden = false;
          collectionInstallCmd.textContent = collInstall(state.collection);
          collectionInstallBtn.dataset.install = collInstall(state.collection);
        } else {
          collectionInstall.hidden = true;
        }
      }

      function renderTagPills() {
        const source = state.authorTags ? TAGS_ALL : TAGS_OUR;
        // Drop selected tags that no longer exist in the active source.
        for (const t of [...state.tags]) if (!source.some((x) => x.value === t)) state.tags.delete(t);
        tagPillsWrap.replaceChildren();
        source.forEach((t, i) => {
          const pill = document.createElement('button');
          pill.type = 'button';
          pill.className = 'tagpill' + (state.tags.has(t.value) ? ' is-active' : '') + (i >= FOLD ? ' folded' : '');
          pill.dataset.tag = t.value;
          pill.innerHTML = `${t.value} <span class="tagpill__n">${t.count}</span>`;
          tagPillsWrap.appendChild(pill);
        });
        tagsClear.hidden = state.tags.size === 0;
        if (source.length > FOLD) {
          tagsToggle.hidden = false;
          const collapsed = tagPillsWrap.dataset.collapsed === 'true';
          tagsToggle.textContent = collapsed ? `Show all ${source.length} tags` : 'Show fewer tags';
        } else {
          tagsToggle.hidden = true;
        }
      }

      let toastTimer;
      function showToast(message) {
        toast.textContent = message;
        toast.hidden = false;
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => (toast.hidden = true), 1600);
      }

      search.addEventListener('input', () => {
        state.q = search.value;
        render();
      });

      groupSel.addEventListener('change', () => {
        state.group = groupSel.value;
        render();
      });

      sortSel.addEventListener('change', () => {
        state.sort = sortSel.value;
        render();
      });

      for (const pill of collectionPills) {
        pill.addEventListener('click', () => {
          for (const p of collectionPills) p.classList.toggle('is-active', p === pill);
          state.collection = pill.dataset.collection;
          render();
        });
      }

      authorTagsToggle.addEventListener('change', () => {
        state.authorTags = authorTagsToggle.checked;
        document.body.classList.toggle('show-author-tags', state.authorTags);
        renderTagPills();
        render();
      });

      tagPillsWrap.addEventListener('click', (event) => {
        const pill = event.target.closest('.tagpill');
        if (!pill) return;
        const tag = pill.dataset.tag;
        if (state.tags.has(tag)) state.tags.delete(tag);
        else state.tags.add(tag);
        pill.classList.toggle('is-active', state.tags.has(tag));
        tagsClear.hidden = state.tags.size === 0;
        render();
      });

      tagsClear.addEventListener('click', () => {
        state.tags.clear();
        renderTagPills();
        render();
      });

      tagsToggle.addEventListener('click', () => {
        const collapsed = tagPillsWrap.dataset.collapsed === 'true';
        tagPillsWrap.dataset.collapsed = collapsed ? 'false' : 'true';
        tagsToggle.setAttribute('aria-expanded', String(collapsed));
        renderTagPills();
      });

      document.addEventListener('click', (event) => {
        const btn = event.target.closest('[data-install]');
        if (!btn) return;
        navigator.clipboard.writeText(btn.dataset.install ?? '').then(
          () => showToast('Install command copied'),
          () => showToast('Copy failed — select manually'),
        );
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === '/' && document.activeElement !== search) {
          event.preventDefault();
          search.focus();
        } else if (event.key === 'Escape' && document.activeElement === search) {
          search.value = '';
          state.q = '';
          render();
        }
      });

      renderTagPills();
      render();
    </script>
  </body>
</html>
