---
interface Skill {
  name: string;
  slug: string;
  collection: string;
  collectionLabel: string;
  tags: string[];
  authorTags: string[];
  version: string | null;
  author: string | null;
  description: string;
  githubUrl: string;
  install: string;
  upstream: { repo: string; path: string | null; ref: string } | null;
}

const { skill } = Astro.props as { skill: Skill };

// Author tags that aren't already in our classification (shown only when opted in).
const authorOnly = skill.authorTags.filter((t) => !skill.tags.includes(t));

// Lowercase haystack for client-side full-text filtering (covers both tag sets).
const haystack = [
  skill.name,
  skill.description,
  skill.author,
  skill.collectionLabel,
  ...skill.tags,
  ...skill.authorTags,
]
  .filter(Boolean)
  .join(' ')
  .toLowerCase();
---

<article
  class="card"
  data-name={skill.name.toLowerCase()}
  data-collection={skill.collection}
  data-collection-label={skill.collectionLabel}
  data-author={skill.author ?? ''}
  data-tags={skill.tags.join(',')}
  data-author-tags={skill.authorTags.join(',')}
  data-search={haystack}
>
  <header class="card__head">
    <h3 class="card__name">{skill.name}</h3>
    {skill.version && <span class="badge badge--version">v{skill.version}</span>}
  </header>

  <div class="card__badges">
    <span class="badge badge--collection">{skill.collectionLabel}</span>
    {
      skill.upstream && (
        <span class="badge badge--upstream" title={`Tracks ${skill.upstream.repo}`}>
          ⇅ synced
        </span>
      )
    }
  </div>

  <p class="card__desc">{skill.description}</p>

  {
    (skill.tags.length > 0 || authorOnly.length > 0) && (
      <ul class="card__tags">
        {skill.tags.slice(0, 6).map((tag) => (
          <li class="tag">{tag}</li>
        ))}
        {authorOnly.slice(0, 6).map((tag) => (
          <li class="tag tag--author">{tag}</li>
        ))}
      </ul>
    )
  }

  <footer class="card__foot">
    <div class="card__meta">
      {skill.author && <span class="card__author" title="Author">{skill.author}</span>}
      {
        skill.upstream && (
          <a
            class="card__origin"
            href={`https://github.com/${skill.upstream.repo}`}
            target="_blank"
            rel="noopener noreferrer"
            title="Origin repository"
          >
            repo: {skill.upstream.repo} ↗
          </a>
        )
      }
    </div>
    <div class="card__actions">
      <button class="btn btn--copy" data-install={skill.install} type="button">
        Copy install
      </button>
      <a class="btn btn--ghost" href={skill.githubUrl} target="_blank" rel="noopener noreferrer">
        GitHub ↗
      </a>
    </div>
  </footer>
</article>
